{
    "name": "mandrael/contao-event-tags",
    "description": "Erweiterung für Contao, um Events zentrale Tags zuzuweisen und Eventlisten nach Tags zu filtern.",
    "type": "contao-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Gasperl"
        }
    ],
    "require": {
        "php": ">=8.1",
        "contao/core-bundle": "^4.13 || ^5.3",
        "contao/calendar-bundle": "^4.13 || ^5.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.5"
    },
    "autoload": {
        "psr-4": {
            "Mandrael\\EventTagsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mandrael\\EventTagsBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Mandrael\\EventTagsBundle\\ContaoManager\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "contao/manager-plugin": true,
            "php-http/discovery": true
        }
    },
    "keywords": [
        "contao",
        "events",
        "tags",
        "calendar",
        "filter"
    ]
}
